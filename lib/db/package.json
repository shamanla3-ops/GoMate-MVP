{
  "name": "@gomate/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "generate": "drizzle-kit generate --config=drizzle.config.cjs",
    "migrate": "drizzle-kit migrate --config=drizzle.config.cjs",
    "studio": "drizzle-kit studio --config=drizzle.config.cjs"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.0"
  },
  "files": [
    "dist",
    "drizzle.config.ts"
  ]
}
