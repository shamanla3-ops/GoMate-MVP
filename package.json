{
  "name": "gomate",
  "version": "0.1.0",
  "private": true,
  "description": "GoMate – global carpooling platform monorepo",
  "scripts": {
    "postinstall": "pnpm --filter @gomate/db build",
    "dev:api": "pnpm --filter api-server dev",
    "dev:web": "pnpm --filter gomate-web dev",
    "build": "pnpm --filter @gomate/db build && pnpm --filter api-server build && pnpm --filter gomate-web build",
    "db:generate": "pnpm --filter @gomate/db generate",
    "db:migrate": "pnpm --filter @gomate/db migrate"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.0.0"
}
